# =============================================================================
# Grainwatch Controller BFF - Environment Configuration
# =============================================================================
# Copy this file to .env and update values for your environment.
# NEVER commit .env files containing secrets to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------

# HTTP port the server listens on
# Default: 3000
PORT=3000

# Environment mode (development, production, test)
# Production mode enforces stricter validation and security
# Default: development
NODE_ENV=production

# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------

# Secret key for signing JWT tokens
# REQUIRED in production - must be at least 32 characters
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-secret-key-minimum-32-characters-long

# Token expiry duration
# Format: number + unit (s=seconds, m=minutes, h=hours, d=days, w=weeks)
# Examples: 1h, 24h, 7d
# Default: 24h
JWT_EXPIRES_IN=24h

# -----------------------------------------------------------------------------
# InfluxDB Connection (InfluxDB 2.x)
# -----------------------------------------------------------------------------

# InfluxDB URL
# For Synology deployment, use the container name or host IP
# Examples: http://influxdb:8086, http://192.168.0.131:8086
# Default: http://localhost:8086
INFLUXDB_URL=http://influxdb:8086

# InfluxDB authentication token
# Generate in InfluxDB UI: Data > API Tokens
# REQUIRED - no default value
INFLUXDB_TOKEN=your-influxdb-token-change-this

# Organization name
# Default: grainwatch
INFLUXDB_ORG=grainwatch

# Bucket name containing sensor measurements
# Default: grainwatch
INFLUXDB_BUCKET=grainwatch

# Measurement name for temperature/humidity data
# Default: Temp
INFLUXDB_MEASUREMENT=Temp

# -----------------------------------------------------------------------------
# User Storage
# -----------------------------------------------------------------------------

# Path to the JSON file containing user credentials and permissions
# The file must be readable and writable by the application
# For Docker deployment, this path is inside the container
# Default: ./data/users.json
USERS_FILE_PATH=/app/data/users.json

# NOTE: On first startup, if no users exist, a default admin user is created:
# Username: admin
# Password: changeme123
# IMPORTANT: Change this password immediately after first login!

# -----------------------------------------------------------------------------
# Docker Network (production only)
# -----------------------------------------------------------------------------

# Name of the Docker network for container communication
# Should match the network your InfluxDB container is connected to
# Default: grainwatch-network
DOCKER_NETWORK=grainwatch-network
