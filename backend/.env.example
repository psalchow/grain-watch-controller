# =============================================================================
# Grainwatch Controller BFF - Environment Configuration
# =============================================================================
# Copy this file to .env and update values for your environment.
# NEVER commit .env files containing secrets to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------

# HTTP port the server listens on
# Default: 3000
PORT=3000

# Environment mode (development, production, test)
# Production mode enforces stricter validation and security
# Default: development
NODE_ENV=production

# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------

# Secret key for signing JWT tokens
# REQUIRED in production - must be at least 32 characters
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-secret-key-minimum-32-characters-long

# Access token expiry duration (keep short; refreshed automatically via cookie)
# Format: number + unit (s=seconds, m=minutes, h=hours, d=days, w=weeks)
# Examples: 15m, 1h
# Default: 15m
JWT_EXPIRES_IN=15m

# Secret key for signing refresh tokens
# REQUIRED in production - at least 32 characters AND different from JWT_SECRET
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_REFRESH_SECRET=your-refresh-secret-minimum-32-characters-long-and-distinct

# Refresh token expiry duration (how long a session survives without re-login)
# Default: 30d
JWT_REFRESH_EXPIRES_IN=30d

# -----------------------------------------------------------------------------
# Refresh-token cookie
# -----------------------------------------------------------------------------

# Whether the refresh cookie requires HTTPS (Secure attribute)
# Default: true in production, false otherwise
COOKIE_SECURE=true

# SameSite attribute: lax | strict | none
# Use 'lax' when frontend and backend share a registrable domain.
# Use 'none' (requires COOKIE_SECURE=true + HTTPS) when they are on different
# domains; also set CORS_ALLOWED_ORIGINS to the exact frontend origin.
# Default: lax
COOKIE_SAMESITE=lax

# -----------------------------------------------------------------------------
# CORS (production only)
# -----------------------------------------------------------------------------

# Comma-separated list of allowed origins (no wildcard when credentials are used)
# Example: https://grainwatch.example.com
CORS_ALLOWED_ORIGINS=

# -----------------------------------------------------------------------------
# InfluxDB Connection (InfluxDB 2.x)
# -----------------------------------------------------------------------------

# InfluxDB URL
# For Synology deployment, use the container name or host IP
# Examples: http://influxdb:8086, http://192.168.0.131:8086
# Default: http://localhost:8086
INFLUXDB_URL=http://influxdb:8086

# InfluxDB authentication token
# Generate in InfluxDB UI: Data > API Tokens
# REQUIRED - no default value
INFLUXDB_TOKEN=your-influxdb-token-change-this

# Organization name
# Default: grainwatch
INFLUXDB_ORG=grainwatch

# Bucket name containing sensor measurements
# Default: grainwatch
INFLUXDB_BUCKET=grainwatch

# Measurement name for temperature/humidity data
# Default: Temp
INFLUXDB_MEASUREMENT=Temp

# Measurement name for outdoor temperature data
# Default: outdoor-temperature
INFLUXDB_OUTDOOR_TEMPERATURE_MEASUREMENT=outdoor-temperature

# Measurement name for outdoor humidity data
# Default: outdoor-humidity
INFLUXDB_OUTDOOR_HUMIDITY_MEASUREMENT=outdoor-humidity

# Look-back window for the latest outdoor reading query (InfluxQL duration).
# Keep short in production; a longer window is fine in development.
# Default: 1h in production, 26w otherwise
INFLUXDB_OUTDOOR_LOOKBACK=1h

# -----------------------------------------------------------------------------
# Database (SQLite)
# -----------------------------------------------------------------------------

# Path to the SQLite database file
# For Docker deployment, this path is inside the container
# Default: ./data/grainwatch.db
DATABASE_PATH=/app/data/grainwatch.db

# NOTE: On first startup, if no users exist, a default admin user is created:
# Username: admin
# Password: changeme123
# IMPORTANT: Change this password immediately after first login!

# -----------------------------------------------------------------------------
# Docker Network (production only)
# -----------------------------------------------------------------------------

# Name of the Docker network for container communication
# Should match the network your InfluxDB container is connected to
# Default: grainwatch-network
DOCKER_NETWORK=grainwatch-network

# MQTT broker (backend-wide; fan control)
MQTT_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=

# Fan control timing
FAN_KEEPALIVE_INTERVAL_MS=900000
FAN_WATCHDOG_TIMEOUT_MS=10000
FAN_EVENT_RETENTION_DAYS=90
FAN_RETENTION_SWEEP_INTERVAL_MS=21600000
